generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (BetterAuth compatible) ───────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  memberships   WorkspaceMember[]
  approvals     Approval[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  expiresAt            DateTime?
  password             String?
  scope                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Workspace / Org ─────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  plan        Plan     @default(FREE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          WorkspaceMember[]
  projects         Project[]
  repositories     Repository[]
  subscriptions    Subscription[]
  githubInstalls   GitHubInstall[]
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model WorkspaceMember {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole   @default(MEMBER)
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  workspaceId         String
  razorpayCustomerId  String?
  razorpaySubId       String?            @unique
  plan                Plan               @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  aiCreditsUsed       Int                @default(0)
  aiCreditsLimit      Int                @default(10)
  repoLimit           Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]
}

// ─── GitHub ───────────────────────────────────────────────────────────────────

model GitHubInstall {
  id             String   @id @default(cuid())
  workspaceId    String
  installationId Int      @unique
  accountLogin   String
  accountType    String
  createdAt      DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositories Repository[]
}

model Repository {
  id             String   @id @default(cuid())
  workspaceId    String
  installId      String?
  githubId       Int      @unique
  fullName       String
  defaultBranch  String   @default("main")
  private        Boolean  @default(false)
  createdAt      DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  install      GitHubInstall? @relation(fields: [installId], references: [id])
  pullRequests PullRequest[]
  features     FeatureRequest[]
}

// ─── Feature Request Lifecycle ───────────────────────────────────────────────

model FeatureRequest {
  id           String              @id @default(cuid())
  projectId    String
  repositoryId String?
  title        String
  description  String
  source       RequestSource       @default(MANUAL)
  status       FeatureStatus       @default(INTAKE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repository Repository? @relation(fields: [repositoryId], references: [id])
  prd        PRD?
  tasks      Task[]
  messages   ClarificationMessage[]
  approvals  Approval[]
  notifications Notification[]
}

enum RequestSource {
  MANUAL
  EMAIL
  SUPPORT_TICKET
  SLACK
  API
}

enum FeatureStatus {
  INTAKE
  CLARIFYING
  READY_FOR_PRD
  GENERATING_PRD
  PRD_READY
  PLANNING
  TASKS_READY
  IN_DEVELOPMENT
  IN_REVIEW
  FIX_NEEDED
  RE_REVIEWING
  PENDING_APPROVAL
  APPROVED
  SHIPPED
  REJECTED
  DUPLICATE
  NOT_NEEDED
}

model ClarificationMessage {
  id        String   @id @default(cuid())
  featureId String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  feature FeatureRequest @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

// ─── PRD ─────────────────────────────────────────────────────────────────────

model PRD {
  id               String   @id @default(cuid())
  featureId        String   @unique
  problemStatement String   @db.Text
  goals            Json
  nonGoals         Json
  userStories      Json
  acceptanceCriteria Json
  edgeCases        Json
  successMetrics   Json
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  feature FeatureRequest @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

// ─── Tasks / Kanban ──────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  featureId   String
  title       String
  description String     @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  feature FeatureRequest @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Pull Requests & Reviews ─────────────────────────────────────────────────

model PullRequest {
  id           String   @id @default(cuid())
  repositoryId String
  featureId    String?
  githubPrId   Int
  number       Int
  title        String
  body         String?  @db.Text
  state        String
  headBranch   String
  baseBranch   String
  htmlUrl      String
  diffUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  reviews    AIReview[]

  @@unique([repositoryId, githubPrId])
}

model AIReview {
  id            String       @id @default(cuid())
  pullRequestId String
  featureId     String?
  status        ReviewStatus @default(PENDING)
  summary       String?      @db.Text
  issues        Json?
  score         Int?
  approved      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  comments    ReviewComment[]
}

enum ReviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model ReviewComment {
  id         String        @id @default(cuid())
  reviewId   String
  file       String?
  line       Int?
  body       String        @db.Text
  severity   IssueSeverity @default(NON_BLOCKING)
  category   String?
  createdAt  DateTime      @default(now())

  review AIReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

enum IssueSeverity {
  BLOCKING
  NON_BLOCKING
  SUGGESTION
}

// ─── Approval ────────────────────────────────────────────────────────────────

model Approval {
  id        String         @id @default(cuid())
  featureId String
  userId    String
  decision  ApprovalDecision
  notes     String?        @db.Text
  createdAt DateTime       @default(now())

  feature FeatureRequest @relation(fields: [featureId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  featureId String?
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature FeatureRequest? @relation(fields: [featureId], references: [id])
}

// ─── Inngest Job Tracking ────────────────────────────────────────────────────

model WorkflowRun {
  id          String          @id @default(cuid())
  featureId   String?
  type        WorkflowType
  status      WorkflowRunStatus @default(RUNNING)
  inngestRunId String?
  result      Json?
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum WorkflowType {
  CLARIFICATION
  PRD_GENERATION
  TASK_GENERATION
  REPO_ANALYSIS
  PR_REVIEW
  RE_REVIEW
  RELEASE_CHECK
}

enum WorkflowRunStatus {
  RUNNING
  COMPLETED
  FAILED
}
